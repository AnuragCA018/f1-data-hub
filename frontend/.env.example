# ──────────────────────────────────────────────────────────────────────────────
# F1 Data Hub — Frontend environment variables
# Copy this file to .env.local for local dev, or set these in your Netlify
# dashboard under Site → Environment variables.
# ──────────────────────────────────────────────────────────────────────────────

# ⚠️  REQUIRED FOR PRODUCTION: Backend API base URL (no trailing slash).
# This project uses Next.js static export (output: "export") which means:
#   • No server-side rewrites possible
#   • Frontend MUST communicate directly with backend
#   • This env var is ESSENTIAL
#
# Set this to your deployed Render backend URL:
NEXT_PUBLIC_API_URL=https://f1-data-hub-kfhe.onrender.com

# Local development: for testing with local backend
BACKEND_URL=http://localhost:8000
