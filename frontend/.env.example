# ──────────────────────────────────────────────────────────────────────────────
# F1 Data Hub — Frontend environment variables
# Copy this file to .env.local for local dev, or set these in your Netlify
# dashboard under Site → Environment variables.
# ──────────────────────────────────────────────────────────────────────────────

# Public backend API base URL (no trailing slash).
# • Local dev: leave empty — Next.js rewrites proxy /api/* → localhost:8000
# • Netlify production: set to your deployed backend URL, e.g.
#     https://your-backend.fly.dev
#   When set, the frontend calls the backend directly (no rewrite needed).
NEXT_PUBLIC_API_URL=

# Used at build-time by next.config.js to configure the /api rewrite proxy.
# Only needed when running `npm run dev` or `npm run build` locally and you
# want to point to a non-default backend port.
# Production hosts: leave empty — set NEXT_PUBLIC_API_URL instead.
BACKEND_URL=http://localhost:8000
