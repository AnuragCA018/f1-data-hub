# ──────────────────────────────────────────────────────────────────────────────
# F1 Data Hub — Backend environment variables
# Copy this file to .env and fill in production values.
# Never commit the real .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins.
# Set this to your Netlify frontend URL in production.
# Example: https://your-app.netlify.app,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Absolute path to the FastF1 disk cache directory.
# Defaults to <backend_dir>/cache when unset.
# On Render/Railway use a persistent disk mount path, e.g. /data/f1cache
# FASTF1_CACHE_DIR=/data/f1cache

# Port to bind (used by the start script; default 8000)
PORT=8000

# Set to "production" on live servers
ENVIRONMENT=development

# Background prewarm of the default hosted pages.
# These values match the frontend defaults so common pages feel faster after boot.
PREWARM_ENABLED=true
PREWARM_YEAR=2024
PREWARM_ROUND=1
PREWARM_DRIVERS=VER,HAM,LEC,NOR
